# =============================================================================
# Paycheck Planner (ryanbudget.com) — environment template
# Copy to .env.local (development) or .env.production (VPS)
#   cp .env.example .env.local
# Generate secrets: openssl rand -base64 32
# NEVER commit real .env files to git.
# =============================================================================

# --- Core (required for production) ---
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://ryanbudget.me
NEXTAUTH_URL=https://ryanbudget.me
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# --- MongoDB (primary database — required for multi-device sync) ---
# Atlas: https://cloud.mongodb.com → Connect → Drivers → copy connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ryanbudget?retryWrites=true&w=majority

# Enable cloud sync on client (required when using MongoDB)
NEXT_PUBLIC_ENABLE_CLOUD_SYNC=true

# --- Email (Resend — password reset & transactional) ---
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Verified domain sender (after DNS setup). Testing only: onboarding@resend.dev
RESEND_FROM_EMAIL=Paycheck Planner <noreply@ryanbudget.me>

# --- Auth (email + password via MongoDB) ---
# NEXTAUTH_SECRET is used if NextAuth session helpers are enabled; planner-session cookie is primary.

# --- Legacy Supabase (not used for auth — optional) ---
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# NEXT_PUBLIC_SUPABASE_ENABLE_DATA=true

# --- Stripe (required for paid subscriptions) ---
STRIPE_SECRET_KEY=sk_live_REPLACE_OR_sk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE
STRIPE_PRICE_MONTHLY=price_REPLACE
STRIPE_PRICE_ANNUAL=price_REPLACE

# --- OpenAI (optional but recommended: NLP, coach, insights, receipt OCR) ---
OPENAI_API_KEY=sk-REPLACE
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# --- Grok / xAI (optional fallback for AI features) ---
# XAI_API_KEY=
# GROK_API_KEY=
# GROK_MODEL=grok-2-latest

# --- Plaid (optional: bank linking) ---
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# PLAID_INSTITUTION_IDS=

# --- Analytics (optional) ---
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Error monitoring (optional) ---
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=

# --- App metadata (optional) ---
NEXT_PUBLIC_APP_VERSION=1.0.0

# --- Feature flags (optional; 1/true = on, 0/false = off) ---
# NEXT_PUBLIC_FEATURE_AI_NLP_TRANSACTIONS=true
# NEXT_PUBLIC_FEATURE_AI_MULTI_WHAT_IF=true
# NEXT_PUBLIC_FEATURE_REFERRAL_PROGRAM=true
# NEXT_PUBLIC_FEATURE_BLOG_RESOURCES=true
# NEXT_PUBLIC_FEATURE_WAITLIST_SIGNUP=true

# --- Local development only ---
# NODE_ENV=development
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000
